specification {
  element module {
    style {
      shape rectangle
    }
  }
  tag proposed {
    color #f59e0b
  }
}

model {
  module a 'A' {
    metadata { folder 'src/a' }
  }
  module b 'B' {
    metadata { folder 'src/b' }
  }
  module c 'C' {
    metadata { folder 'src/c' }
  }

  a -> b
}

views {
  view index {
    include *
  }
}
