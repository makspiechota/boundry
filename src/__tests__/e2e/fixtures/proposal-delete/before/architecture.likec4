specification {
  element module {
    style { shape rectangle }
  }
  // Proposed additions are amber; proposed deletions are red. Approving strips
  // the amber marker (the edge stays) but removes anything red outright.
  tag proposed {
    color #f59e0b
  }
  tag proposal-delete {
    color #ef4444
  }
}

model {
  module api 'API' {
    metadata { folder 'src/api' }
  }
  module domain 'Domain' {
    metadata { folder 'src/domain' }
  }
  module legacy 'Legacy' {
    #proposal-delete
    metadata { folder 'src/legacy' }
  }

  api -> domain
  api -> legacy #proposal-delete
}

views {
  view index {
    include *
  }
}
