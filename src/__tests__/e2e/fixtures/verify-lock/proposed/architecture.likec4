specification {
  element module {
    style { shape rectangle }
  }
  tag proposed {
    color #f59e0b
  }
}

model {
  module a 'A' {
    metadata { folder 'src/a' }
  }
  module b 'B' {
    metadata { folder 'src/b' }
  }
  module c 'C' {
    metadata { folder 'src/c' }
  }

  a -> b
  // Added the same edge, but as a proposal — excluded from the allow-list, so it
  // is not a self-approval and verify against the lock must pass.
  a -> c #proposed
}

views {
  view index {
    include *
  }
}
