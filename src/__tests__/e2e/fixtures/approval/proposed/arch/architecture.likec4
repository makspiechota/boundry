specification {
  color proposed #f59e0b
  element module {
    style {
      shape rectangle
      color green
    }
  }
  tag proposed
}

model {
  module api 'API' {
    metadata { folder 'src/api' }
  }
  module domain 'Domain' {
    metadata { folder 'src/domain' }
  }
  module shared 'Shared Kernel' {
    metadata { folder 'src/shared' }
  }

  api -> domain
  api -> shared
  domain -> shared {
    #proposed
    style {
      color proposed
      line dashed
    }
  }
}

views {
  view index {
    include *
  }
}
