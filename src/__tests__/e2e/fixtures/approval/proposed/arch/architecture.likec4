specification {
  element module {
    style {
      shape rectangle
    }
  }
  tag proposed {
    color #f59e0b
  }
}

model {
  module api 'API' {
    metadata { folder 'src/api' }
  }
  module domain 'Domain' {
    metadata { folder 'src/domain' }
  }
  module shared 'Shared Kernel' {
    #proposed
    metadata { folder 'src/shared' }
  }

  api -> domain
  api -> shared
  domain -> shared #proposed
}

views {
  view index {
    include *
  }
}
