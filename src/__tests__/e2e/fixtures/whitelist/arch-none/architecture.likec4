specification {
  element module {
    style {
      shape rectangle
      color green
    }
  }
}

model {
  module a 'A' {
    metadata { folder 'src/a' }
  }
  module b 'B' {
    metadata { folder 'src/b' }
  }
  module c 'C' {
    metadata { folder 'src/c' }
  }

  // No relationships drawn on purpose: nothing is whitelisted, so every
  // cross-module import must be blocked.
}

views {
  view index {
    include *
  }
}
