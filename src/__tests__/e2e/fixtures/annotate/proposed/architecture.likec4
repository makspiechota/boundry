specification {
  element module {
    style { shape rectangle }
  }
  tag proposed {
    color #f59e0b
  }
  tag proposal-delete {
    color #ef4444
  }
}

model {
  module api 'API' {
    metadata { folder 'src/api' }
  }
  module domain 'Domain' {
    metadata { folder 'src/domain' }
  }
  module legacy 'Legacy' {
    metadata { folder 'src/legacy' }
  }

  api -> domain
  // An approved addition ends up in the lock...
  api -> legacy #proposed
  // ...and an approved deletion is gone from it.
  domain -> legacy #proposal-delete
}

views {
  view index {
    include *
  }
}
