specification {
  element module {
    style {
      shape rectangle
      color green
    }
  }
}

model {
  module domain "Domain" {
    metadata {
      folder 'src/domain'
    }
  }

  module infra "Infrastructure" {
    metadata {
      folder 'src/infra'
    }
  }

  infra -> domain "Depends on"
}

views {
  view index {
    include *
  }
}
